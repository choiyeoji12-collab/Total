#include "xparameters.h"
#include "xintc.h"
#include "xil_exception.h"
#include "xil_printf.h"

#include "ap_main.h"
#include "../common/common.h"
#include "UpCounter/UpCounter.h"

#define INTC_DEV_ID 	XPAR_INTC_0_DEVICE_ID
#define TMR1_DEV_ID		XPAR_TMR_1_DEVICE_ID
#define TMR2_DEV_ID		XPAR_TMR_2_DEVICE_ID

typedef struct {
	uint32_t CR;
	uint32_t PSC;
	uint32_t ARR;
	uint32_t CNT;
} TMR_Typedef_t;

#define TMR1_BASEADDR	XPAR_TMR_1_S00_AXI_BASEADDR
#define TMR2_BASEADDR	XPAR_TMR_2_S00_AXI_BASEADDR

#define TMR1			((TMR_Typedef_t *)(TMR1_BASEADDR))
#define TMR2			((TMR_Typedef_t *)(TMR2_BASEADDR))

#define TMR_ENABLE_BIT	0
#define TMR_CLEAR_BIT	1
#define TMR_INTR_BIT	2

void TMR_SetPSC(TMR_Typedef_t *TMRx, uint32_t psc)
{
	TMRx->PSC = psc;
}

void TMR_SetARR(TMR_Typedef_t *TMRx, uint32_t arr)
{
	TMRx->ARR = arr;
}

void TMR_StartIntr(TMR_Typedef_t *TMRx)
{
	TMRx->CR |= 1<<TMR_INTR_BIT;
}

void TMR_StopIntr(TMR_Typedef_t *TMRx)
{
	TMRx->CR &= ~(1<<TMR_INTR_BIT);
}

void TMR_StartTimer(TMR_Typedef_t *TMRx)
{
	TMRx->CR |= 1<<TMR_ENABLE_BIT;
}

void TMR_StopTimer(TMR_Typedef_t *TMRx)
{
	TMRx->CR &= ~(1<<TMR_ENABLE_BIT);
}

void TMR_ClearTimer(TMR_Typedef_t *TMRx)
{
	TMRx->CR |= 1<<TMR_CLEAR_BIT;
	TMRx->CR &= ~(1<<TMR_CLEAR_BIT);
}

XIntc IntrController;

void TMR1_ISR(void *CallbackRef)
{
	xil_printf("1sec	TIMER 1 ISR!\n");
}

void TMR2_ISR(void *CallbackRef)
{
	xil_printf("2sec	TIMER 2 ISR!\n");
}

int SetupInterruptSystem()
{
	int status;

	// 1. άΈ≈ΆΖ¥Τ° ΡΝΤ°Ζ―Ζ· Ο ±β»≠
	status = XIntc_Initialize(&IntrController, INTC_DEV_ID);
	if (status != XST_SUCCESS) {
		return XST_FAILURE;
	}

	// 2-1. TMR1_ISR «‘ΦωΗΠ IntcΩΆ Ω§Αα
	status = XIntc_Connect(&IntrController, TMR1_DEV_ID, (XInterruptHandler)TMR1_ISR, (void *)0);
	if (status != XST_SUCCESS) {
		return XST_FAILURE;
	}
	// 2-2. TMR2_ISR «‘ΦωΗΠ IntcΩΆ Ω§Αα
	status = XIntc_Connect(&IntrController, TMR2_DEV_ID, (XInterruptHandler)TMR2_ISR, (void *)0);
	if (status != XST_SUCCESS) {
		return XST_FAILURE;
	}

	// 3. Interrupt Controller ΫΟάέ (Hardware Mode)
	status = XIntc_Start(&IntrController, XIN_REAL_MODE);
	if (status != XST_SUCCESS) {
		return XST_FAILURE;
	}

	// 4. ΑΔΑΔά« άΈ≈ΆΖ¥Τ° ΟΛ≥Έ »ΑΦΚ»≠
	XIntc_Enable(&IntrController, TMR1_DEV_ID);
	XIntc_Enable(&IntrController, TMR2_DEV_ID);

	// 5. MicroBlazeά« Exception Ο ±β»≠ ΙΉ »ΑΦΚ»≠
	Xil_ExceptionInit();
	Xil_ExceptionRegisterHandler(XIL_EXCEPTION_ID_INT,
			(Xil_ExceptionHandler)XIntc_InterruptHandler,
			&IntrController);
	Xil_ExceptionEnable();

	return XST_SUCCESS;
}

void ap_init()
{
	UpCounter_Init();
	SetupInterruptSystem();

	TMR_SetPSC(TMR1, 100-1);
	TMR_SetARR(TMR1, 1000000-1);
	TMR_StartIntr(TMR1);
	TMR_StartTimer(TMR1);

	TMR_SetPSC(TMR2, 100-1);
	TMR_SetARR(TMR2, 2000000-1);
	TMR_StartIntr(TMR2);
	TMR_StartTimer(TMR2);
}

void ap_excute()
{
	while (1)
	{
		UpCounter_Excute();

		millis_inc();
		delay_ms(1);
	}
}
